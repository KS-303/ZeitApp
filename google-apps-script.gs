function doGet(e){return ContentService.createTextOutput(JSON.stringify({ok:true,message:"Webhook läuft"})).setMimeType(ContentService.MimeType.JSON)}

function doPost(e){var ss=SpreadsheetApp.getActiveSpreadsheet();var dataSheet=ss.getSheetByName('Zeiten')||ss.insertSheet('Zeiten');var summarySheet=ss.getSheetByName('Monatsauswertung')||ss.insertSheet('Monatsauswertung');var data=JSON.parse(e.postData.contents||'{}');if(dataSheet.getLastRow()===0){dataSheet.appendRow(['EintragID','Woche','Monat','Datum','Typ','Anteil','Mitarbeiter','Baustelle','Fahrzeug','Arbeitsbeginn','Arbeitsende','Arbeitsminuten','FahrzeitMin','PauseMin','Kilometer','Liter','Tankkosten','Kilometerstand','Notizen','ExportiertAm'])}var lastRow=dataSheet.getLastRow(),idRowMap={};if(lastRow>1){var idValues=dataSheet.getRange(2,1,lastRow-1,1).getValues();idValues.forEach(function(r,idx){if(r[0])idRowMap[String(r[0])]=idx+2})}var inserted=0,updated=0;(data.entries||[]).forEach(function(entry){var entryId=String(entry.id||'');if(!entryId)return;var month=String(entry.date||'').slice(0,7);var row=[entryId,data.week||'',month,entry.date||'',entry.entryType||'arbeit',entry.dayFraction||1,entry.employee||'',entry.site||'',entry.vehicle||'',entry.workStart||'',entry.workEnd||'',entry.workMinutes||0,entry.driveMinutes||0,entry.breakMinutes||0,entry.kilometers||0,entry.fuelLiters||0,entry.fuelAmount||0,entry.odometer||0,entry.notes||'',new Date()];if(idRowMap[entryId]){dataSheet.getRange(idRowMap[entryId],1,1,row.length).setValues([row]);updated++}else{dataSheet.appendRow(row);inserted++}});rebuildMonthlySummary_(dataSheet,summarySheet);return ContentService.createTextOutput(JSON.stringify({ok:true,inserted:inserted,updated:updated})).setMimeType(ContentService.MimeType.JSON)}
function rebuildMonthlySummary_(dataSheet,summarySheet){summarySheet.clearContents();summarySheet.appendRow(['Monat','Mitarbeiter','Arbeitsstunden','Fahrstunden','Pausenstunden','Kilometer','Tankkosten','Urlaubstage','Kranktage','Feiertage']);var lastRow=dataSheet.getLastRow();if(lastRow<2)return;var values=dataSheet.getRange(2,1,lastRow-1,20).getValues(),map={};values.forEach(function(r){var month=r[2]||'',employee=r[6]||'',type=r[4]||'arbeit',fraction=Number(r[5]||1),key=month+'|'+employee;if(!map[key])map[key]={month:month,employee:employee,work:0,drive:0,breaks:0,km:0,fuel:0,urlaub:0,krank:0,ft:0};map[key].work+=Number(r[11]||0);map[key].drive+=Number(r[12]||0);map[key].breaks+=Number(r[13]||0);map[key].km+=Number(r[14]||0);map[key].fuel+=Number(r[16]||0);if(type==='urlaub')map[key].urlaub+=fraction;if(type==='krank')map[key].krank+=fraction;if(type==='feiertag')map[key].ft+=fraction});Object.keys(map).sort().forEach(function(key){var x=map[key];summarySheet.appendRow([x.month,x.employee,round2_(x.work/60),round2_(x.drive/60),round2_(x.breaks/60),round2_(x.km),round2_(x.fuel),x.urlaub,x.krank,x.ft])})}
function round2_(value){return Math.round(Number(value||0)*100)/100}